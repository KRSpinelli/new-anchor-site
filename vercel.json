{
api.anchorinnovate.com    "buildCommand": "npm run build",
    "outputDirectory": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
        {
            "source": "/projects/parametric-particles",
            "destination": "https://parametric-particles.vercel.app/"
        },
        {
            "source": "/projects/parametric-particles/",
            "destination": "https://parametric-particles.vercel.app/"
        },
        {
            "source": "/projects/parametric-particles/assets/:path*",
            "destination": "https://parametric-particles.vercel.app/assets/:path*"
        },
        {
            "source": "/projects/ai-rpg/api/(.*)",
            "destination": "https://api.anchorinnovate.com/$1"
        },
        {
      "source": "/projects/ai-rpg/:path*",
      "destination": "https://ai-rpg-blue.vercel.app/projects/ai-rpg/:path*"
    },
    {
      "source": "/projects/ai-rpg",
      "destination": "https://ai-rpg-blue.vercel.app/projects/ai-rpg"
    }
    ]
}
